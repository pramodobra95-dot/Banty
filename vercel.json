{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.ts" },
    { "source": "/assets/:path*", "destination": "/dist/assets/:path*" },
    { "source": "/favicon.png", "destination": "/dist/favicon.png" },
    { "source": "/((?!api|assets|favicon.png|.*\\..*).*)", "destination": "/dist/index.html" }
  ]
}
